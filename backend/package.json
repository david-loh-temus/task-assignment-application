{
  "name": "task-assignment-service",
  "version": "1.0.0",
  "description": "Task Assignment API Service",
  "author": "David Loh",
  "private": true,
  "main": "index.js",
  "scripts": {
    "prebuild": "rm -rf build",
    "build": "tsgo -b",
    "serve": "node build/index.js",
    "start": "npm run build && npm run serve",
    "dev": "TZ=utc ts-node-dev --respawn --transpile-only --ignore-watch node_modules src/index.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --check '**/*.{ts,json}' --ignore-path .gitignore",
    "format:fix": "prettier --write '**/*.{ts,json}' --ignore-path .gitignore",
    "test": "TZ=utc NODE_ENV=test jest --passWithNoTests --runInBand --detectOpenHandles --forceExit --no-cache --coverage --coveragePathIgnorePatterns='src/db/migrations'",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsgo --noEmit --pretty",
    "migration:up": "node-pg-migrate up",
    "migration:down": "node-pg-migrate down",
    "migration:create": "node-pg-migrate create",
    "seed:create": "node-pg-migrate create -t seed",
    "seed:run": "node-pg-migrate up --type seed",
    "seed:down": "node-pg-migrate down --type seed",
    "prepare": "husky install"
  },
  "dependencies": {
    "axios": "1.13.6",
    "cors": "2.8.6",
    "dotenv": "17.3.1",
    "express": "5.2.1",
    "helmet": "8.1.0",
    "http-status-codes": "2.3.0",
    "kysely": "0.28.12",
    "node-pg-migrate": "8.0.4",
    "pg": "8.20.0",
    "pino": "10.3.1",
    "sql-template-strings": "2.2.2",
    "swagger-jsdoc": "6.2.8",
    "swagger-ui-express": "5.0.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/node": "22.0.0",
    "@types/supertest": "7.2.0",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "@typescript-eslint/parser": "8.57.1",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-no-secrets": "2.3.3",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-sonarjs": "4.0.2",
    "eslint-plugin-sql": "3.4.1",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "jest-mock-extended": "4.0.0",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "supertest": "7.2.2",
    "ts-jest": "29.4.6",
    "ts-node-dev": "2.0.0",
    "tsc-files": "1.1.4",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  }
}
